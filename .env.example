# --- API service ---
# Port the Hono API/SPA server listens on (Railway injects PORT in prod).
PORT=3000

# Public base URL for portal links in emails (dev = Vite dev server).
APP_BASE_URL=http://localhost:5173

# --- Database (Phase 1) ---
# Local docker Postgres; Railway provides this in prod.
DATABASE_URL=postgres://tl:tl@localhost:5432/tl

# --- File storage / S3 bucket (Phase 3) ---
BUCKET_ENDPOINT=http://localhost:9000
BUCKET_ACCESS_KEY_ID=tl-minio
BUCKET_SECRET_ACCESS_KEY=tl-minio-secret
BUCKET_NAME=tl-documents
BUCKET_REGION=us-east-1
BUCKET_FORCE_PATH_STYLE=true

# --- AI review (Phase 5) — blank => "AI review unavailable" ---
GEMINI_API_KEY=

# --- Email (Phase 6) — blank => preview mode (logged, not sent) ---
RESEND_API_KEY=
RESEND_FROM=compliance@example.com
